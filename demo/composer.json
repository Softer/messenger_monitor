{
    "name": "softer/messenger-monitor-demo",
    "description": "Demo app for softlab/messenger-monitor-bundle",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^2.0",
        "softlab/messenger-monitor-bundle": "@dev",
        "symfony/doctrine-messenger": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/messenger": "^7.0",
        "symfony/twig-bundle": "^7.0",
        "symfony/yaml": "^7.0",
        "twig/twig": "^3.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
